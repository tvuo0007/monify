# Mail configuration
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-mail-username
MAIL_PASSWORD=your-mail-password
MAIL_FROM_EMAIL=your-sender@example.com

# Database configuration (used by Spring Boot app)
DB_URL=jdbc:mysql://localhost:3306/moneymanager
DB_USERNAME=root
DB_PASSWORD=your-db-password

# MySQL container configuration (used by docker-compose)
MYSQL_DATABASE=moneymanager
MYSQL_USERNAME=root
MYSQL_PASSWORD=your-db-password

# App configuration
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:8080/api/v1.0

# JWT configuration
JWT_SECRET=change-me-to-a-long-random-secret
